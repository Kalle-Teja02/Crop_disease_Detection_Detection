# ============================================================================
# Crop Disease Detection - Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control (it contains sensitive data)
# ============================================================================

# MySQL Configuration
# Leave empty or comment out to disable MySQL (use SQLite + JSON only)
MYSQL_HOST=localhost
MYSQL_USER=crop_disease_user
MYSQL_PASSWORD=your_secure_password
MYSQL_DB=crop_disease_db

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Upload Configuration
MAX_UPLOAD_SIZE=16777216  # 16MB in bytes

# Model Configuration
MODEL_PATH=model_cnn.pkl
CONFIDENCE_THRESHOLD=60  # Minimum confidence percentage for predictions

# Storage Configuration
HISTORY_FILE=detection_history.json
SQLITE_DB=predictions.db
